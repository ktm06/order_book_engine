`timescale 1ns/1ps

module Message_Decoder 
#(
	parameter CLK_RATE_HZ = 50000000,
	parameter DATA_BITS = 8, // should be 8
	parameter MESSAGE_LENGTH = 10
) (
	input [DATA_BITS*MESSAGE_LENGTH:0] inbits,
	input logic message_ready,
	output logic [7:0] msgtype,
	output logic [31:0] price,
	output logic [7:0]side,
	output logic [31:0]size,
	output logic msg_decoded,
	input CLK,
	input RESET
	
);



always_ff @(posedge CLK) begin
	if (RESET) begin
		size <= '0;
		price <= '0;
		side <= '0;
		msgtype <= '0;
		msg_decoded <= 1'b0;
	end else if (message_ready) begin
		size <= inbits[31:0];
		price <= inbits[63:32];
		side <= inbits[71:64];
		msgtype <= inbits[79:72];
		msg_decoded <= 1'b1;
	end else begin
		msg_decoded <= 1'b0;
	end
end

endmodule
	